// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// PUBLIC SCHEMA — Global / cross-tenant tables
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id           String  @id @default(uuid()) @db.Uuid
  companyCode  String  @unique @map("company_code") @db.VarChar(50)
  companyName  String  @map("company_name") @db.VarChar(255)
  schemaName   String  @map("schema_name") @db.VarChar(100)
  logoUrl      String? @map("logo_url") @db.VarChar(500)
  contactEmail String  @map("contact_email") @db.VarChar(255)
  isActive     Boolean @default(true) @map("is_active")

  @@map("companies")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT SCHEMA — Per-company isolated tables
// Schema name is dynamic at runtime (e.g. tenant_pharmacore, tenant_medsync).
// In code, set search_path or use a per-tenant Prisma client instance.
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id           String   @id @default(uuid()) @db.Uuid
  roleName     String   @unique @map("role_name") @db.VarChar(100)
  roleGroup    String?  @map("role_group") @db.VarChar(50)
  /// JSONB permissions map e.g. {"batch":"full","users":"read"}
  permissions  Json     @default("{}")
  isSystemRole Boolean  @default(false) @map("is_system_role")
  isActive     Boolean  @default(true) @map("is_active")
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users User[]

  @@map("roles")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  roleId             String    @map("role_id") @db.Uuid
  username           String    @unique @db.VarChar(100)
  email              String    @unique @db.VarChar(255)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  firstName          String    @map("first_name") @db.VarChar(100)
  lastName           String    @map("last_name") @db.VarChar(100)
  employeeCode       String?   @unique @map("employee_code") @db.VarChar(50)
  profilePicUrl      String?   @map("profile_pic_url") @db.VarChar(500)
  dateOfJoining      DateTime? @map("date_of_joining") @db.Date
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdById        String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // ── TOTP / 2FA (alter_user_table.sql) ──────────────────────────────────────
  totpSecret     String?   @map("totp_secret")
  totpEnabled    Boolean   @default(false) @map("totp_enabled")
  totpLastUsedAt DateTime? @map("totp_last_used_at") @db.Timestamptz(6)
  twoFaResetBy   String?   @map("two_fa_reset_by") @db.Uuid
  twoFaResetAt   DateTime? @map("two_fa_reset_at") @db.Timestamptz(6)

  // ── Relations ───────────────────────────────────────────────────────────────
  role               Role              @relation(fields: [roleId], references: [id])
  /// User who created this account (self-referencing)
  createdByUser      User?             @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers       User[]            @relation("CreatedBy")
  /// Admin who last reset 2FA for this user (self-referencing)
  twoFaResetByUser   User?             @relation("TwoFaReset", fields: [twoFaResetBy], references: [id], onDelete: SetNull)
  twoFaResetForUsers User[]            @relation("TwoFaReset")
  refreshTokens      RefreshToken[]
  loginAuditLogs     LoginAudit[]
  totpBackupCodes    TotpBackupCode[]
  createdRoomTypes    RoomType[]        @relation("RoomTypeCreatedBy")
  updatedRoomTypes    RoomType[]        @relation("RoomTypeUpdatedBy")
  createdProcessTypes ProcessType[]     @relation("ProcessTypeCreatedBy")
  updatedProcessTypes ProcessType[]     @relation("ProcessTypeUpdatedBy")
  createdCleaningEquip    CleaningEquipment[]  @relation("CleaningEquipmentCreatedBy")
  updatedCleaningEquip    CleaningEquipment[]  @relation("CleaningEquipmentUpdatedBy")
  createdPackagingTypes   PackagingType[]      @relation("PackagingTypeCreatedBy")
  updatedPackagingTypes   PackagingType[]      @relation("PackagingTypeUpdatedBy")
  createdFunctionTypes    FunctionType[]       @relation("FunctionTypeCreatedBy")
  updatedFunctionTypes    FunctionType[]       @relation("FunctionTypeUpdatedBy")
  createdRoomCleaningTypes    RoomCleaningType[]   @relation("RoomCleaningTypeCreatedBy")
  updatedRoomCleaningTypes    RoomCleaningType[]   @relation("RoomCleaningTypeUpdatedBy")
  createdRoomCleaningSopSteps RoomCleaningSopStep[] @relation("RoomCleaningSopStepCreatedBy")
  updatedRoomCleaningSopSteps RoomCleaningSopStep[] @relation("RoomCleaningSopStepUpdatedBy")
  authorizedRoomCleaningSopSteps RoomCleaningSopStep[] @relation("RoomCleaningSopStepAuthorizedBy")
  createdRoomInspection1SopSteps RoomInspection1SopStep[] @relation("RoomInspection1SopStepCreatedBy")
  updatedRoomInspection1SopSteps RoomInspection1SopStep[] @relation("RoomInspection1SopStepUpdatedBy")
  uploadedInsp1Media             RoomInspection1SopStepMedia[] @relation("Insp1MediaUploadedBy")
  createdRoomInspection2SopSteps RoomInspection2SopStep[] @relation("RoomInspection2SopStepCreatedBy")
  updatedRoomInspection2SopSteps RoomInspection2SopStep[] @relation("RoomInspection2SopStepUpdatedBy")
  uploadedInsp2Media             RoomInspection2SopStepMedia[] @relation("Insp2MediaUploadedBy")
  createdRoomQacSopSteps         RoomQacSopStep[] @relation("RoomQacSopStepCreatedBy")
  updatedRoomQacSopSteps         RoomQacSopStep[] @relation("RoomQacSopStepUpdatedBy")
  uploadedQacMedia               RoomQacSopStepMedia[] @relation("QacMediaUploadedBy")
  createdEquCleaningSopSteps     EquCleaningSopStep[] @relation("EquCleaningSopStepCreatedBy")
  updatedEquCleaningSopSteps     EquCleaningSopStep[] @relation("EquCleaningSopStepUpdatedBy")
  authorizedEquCleaningSopSteps  EquCleaningSopStep[] @relation("EquCleaningSopStepAuthorizedBy")
  uploadedEquSopMedia            EquCleaningSopStepMedia[] @relation("EquSopMediaUploadedBy")
  createdEquInsp1SopSteps        EquInspection1SopStep[] @relation("EquInsp1SopStepCreatedBy")
  updatedEquInsp1SopSteps        EquInspection1SopStep[] @relation("EquInsp1SopStepUpdatedBy")
  uploadedEquInsp1Media          EquInspection1SopStepMedia[] @relation("EquInsp1MediaUploadedBy")
  createdEquInsp2SopSteps        EquInspection2SopStep[] @relation("EquInsp2SopStepCreatedBy")
  updatedEquInsp2SopSteps        EquInspection2SopStep[] @relation("EquInsp2SopStepUpdatedBy")
  uploadedEquInsp2Media          EquInspection2SopStepMedia[] @relation("EquInsp2MediaUploadedBy")
  createdEquQacSopSteps          EquQacSopStep[] @relation("EquQacSopStepCreatedBy")
  updatedEquQacSopSteps          EquQacSopStep[] @relation("EquQacSopStepUpdatedBy")
  uploadedEquQacMedia            EquQacSopStepMedia[] @relation("EquQacMediaUploadedBy")
  createdStandardWeights         StandardWeight[] @relation("StandardWeightCreatedBy")
  updatedStandardWeights         StandardWeight[] @relation("StandardWeightUpdatedBy")
  createdScales                  Scale[] @relation("ScaleCreatedBy")
  updatedScales                  Scale[] @relation("ScaleUpdatedBy")

  @@index([username])
  @@index([isActive])
  @@map("users")
}

model LoginAttempt {
  id             BigInt         @id @default(autoincrement())
  identifier     String         @db.VarChar(255)
  identifierType String         @map("identifier_type") @db.VarChar(10)
  attemptCount   Int            @default(1) @map("attempt_count")
  lockedUntil    DateTime?      @map("locked_until") @db.Timestamptz(6)
  lastAttemptAt  DateTime       @default(now()) @map("last_attempt_at") @db.Timestamptz(6)

  @@unique([identifier, identifierType])
  @@index([identifier, identifierType])
  @@map("login_attempts")
}

model LoginAudit {
  id                BigInt         @id @default(autoincrement())
  userId            String?        @map("user_id") @db.Uuid
  usernameAttempted String         @map("username_attempted") @db.VarChar(100)
  eventType         String         @map("event_type") @db.VarChar(30)
  /// IPv4 / IPv6 stored as text; PostgreSQL INET type
  ipAddress         String?        @map("ip_address")
  userAgent         String?        @map("user_agent")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("login_audit")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  isRevoked  Boolean  @default(false) @map("is_revoked")
  deviceInfo String?  @map("device_info") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("refresh_tokens")
}

/// One-time TOTP recovery codes. Each code is bcrypt-hashed before storage.
/// Codes are single-use — is_used flips to TRUE and used_at is stamped atomically.
model TotpBackupCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  /// bcrypt hash of the plaintext backup code. Raw code shown to user once, then discarded.
  codeHash  String    @map("code_hash") @db.VarChar(255)
  isUsed    Boolean   @default(false) @map("is_used")
  /// NULL while is_used = FALSE; set in the same transaction that flips is_used (GMP audit).
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId], map: "idx_totp_backup_codes_unused")
  @@map("totp_backup_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONFIGURATION — Master data tables (one-time setup by admins)
// ─────────────────────────────────────────────────────────────────────────────

model RoomType {
  id              String   @id @default(uuid()) @db.Uuid
  /// Human-readable code: RT-001, RT-002 …
  roomTypeId      String   @unique @map("room_type_id") @db.VarChar(20)
  roomTypeName    String   @unique @map("room_type_name") @db.VarChar(150)
  roomTypeDetails String?  @map("room_type_details")
  displayOrder    Int      @default(0) @map("display_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdBy       String?  @map("created_by") @db.Uuid
  updatedBy       String?  @map("updated_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdByUser User? @relation("RoomTypeCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("RoomTypeUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([displayOrder])
  @@map("room_types")
}

model ProcessType {
  id                  String   @id @default(uuid()) @db.Uuid
  /// Human-readable code: PR-001, PR-002 …
  processId           String   @unique @map("process_id") @db.VarChar(20)
  processType         String   @unique @map("process_type") @db.VarChar(150)
  processDetails      String?  @map("process_details")
  processGroup        String?  @map("process_group") @db.VarChar(100)
  typicalDurationMin  Int?     @map("typical_duration_min")
  requiresCleanRoom   Boolean  @default(false) @map("requires_clean_room")
  displayOrder        Int      @default(0) @map("display_order")
  isActive            Boolean  @default(true) @map("is_active")
  createdBy           String?  @map("created_by") @db.Uuid
  updatedBy           String?  @map("updated_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdByUser User? @relation("ProcessTypeCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("ProcessTypeUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([processGroup])
  @@index([displayOrder])
  @@map("process_types")
}

model CleaningEquipment {
  id                      String   @id @default(uuid()) @db.Uuid
  /// Human-readable code: CE-001, CE-002 …
  equipmentCode           String   @unique @map("equipment_code") @db.VarChar(20)
  equipmentName           String   @unique @map("equipment_name") @db.VarChar(150)
  equipmentDetails        String?  @map("equipment_details")
  /// dry | wet | sanitizing | general
  cleaningType            String   @default("general") @map("cleaning_type") @db.VarChar(20)
  material                String?  @map("material") @db.VarChar(100)
  requiresReplacement     Boolean  @default(false) @map("requires_replacement")
  replacementIntervalDays Int?     @map("replacement_interval_days")
  displayOrder            Int      @default(0) @map("display_order")
  isActive                Boolean  @default(true) @map("is_active")
  createdBy               String?  @map("created_by") @db.Uuid
  updatedBy               String?  @map("updated_by") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdByUser User? @relation("CleaningEquipmentCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("CleaningEquipmentUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([cleaningType])
  @@index([displayOrder])
  @@map("cleaning_equipment")
}

model PackagingType {
  id                    String   @id @default(uuid()) @db.Uuid
  /// Human-readable code: PT-001, PT-002 …
  packagingTypeId       String   @unique @map("packaging_type_id") @db.VarChar(20)
  packagingTypeName     String   @unique @map("packaging_type_name") @db.VarChar(150)
  packagingTypeDetails  String?  @map("packaging_type_details")
  /// blister | bottle | sachet | strip | vial | ampoule | tube | pouch | other
  packagingCategory     String?  @map("packaging_category") @db.VarChar(20)
  primaryMaterial       String?  @map("primary_material") @db.VarChar(100)
  packUnit              String?  @map("pack_unit") @db.VarChar(50)
  standardPackSize      Int?     @map("standard_pack_size")
  storageConditions     String?  @map("storage_conditions") @db.VarChar(150)
  displayOrder          Int      @default(0) @map("display_order")
  isActive              Boolean  @default(true) @map("is_active")
  createdBy             String?  @map("created_by") @db.Uuid
  updatedBy             String?  @map("updated_by") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdByUser User? @relation("PackagingTypeCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("PackagingTypeUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([packagingCategory])
  @@index([displayOrder])
  @@map("packaging_types")
}

model FunctionType {
  id                    String   @id @default(uuid()) @db.Uuid
  /// Human-readable code: FT-001, FT-002 …
  functionTypeId        String   @unique @map("function_type_id") @db.VarChar(20)
  functionTypeName      String   @unique @map("function_type_name") @db.VarChar(100)
  functionTypeDetails   String?  @map("function_type_details")
  canSignOff            Boolean  @default(false) @map("can_sign_off")
  canOperateBatch       Boolean  @default(false) @map("can_operate_batch")
  canPerformCleaning    Boolean  @default(false) @map("can_perform_cleaning")
  canPerformMaintenance Boolean  @default(false) @map("can_perform_maintenance")
  displayOrder          Int      @default(0) @map("display_order")
  isActive              Boolean  @default(true) @map("is_active")
  createdBy             String?  @map("created_by") @db.Uuid
  updatedBy             String?  @map("updated_by") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdByUser User? @relation("FunctionTypeCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("FunctionTypeUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([displayOrder])
  @@map("function_types")
}

model RoomCleaningType {
  id                  String   @id @default(uuid()) @db.Uuid
  /// Auto-generated code: RCT-001, RCT-002 …
  cleaningTypeCode    String   @unique @map("cleaning_type_code") @db.VarChar(20)
  cleaningTypeName    String   @unique @map("cleaning_type_name") @db.VarChar(150)
  cleaningTypeDetails String?  @map("cleaning_type_details")
  /// TypeA=Dry, TypeB=Wet, TypeC=Sanitization
  defaultMethod       String?  @map("default_method") @db.VarChar(10)
  displayOrder        Int      @default(0) @map("display_order")
  isActive            Boolean  @default(true) @map("is_active")
  createdBy           String?  @map("created_by") @db.Uuid
  updatedBy           String?  @map("updated_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdByUser User?                @relation("RoomCleaningTypeCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser User?                @relation("RoomCleaningTypeUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  sopSteps         RoomCleaningSopStep[]
  inspection1Steps RoomInspection1SopStep[]
  inspection2Steps RoomInspection2SopStep[]
  qacSteps         RoomQacSopStep[]
  equCleaningSteps EquCleaningSopStep[]
  equInspection1Steps EquInspection1SopStep[]
  equInspection2Steps EquInspection2SopStep[]
  equQacSteps         EquQacSopStep[]

  @@index([isActive])
  @@index([displayOrder])
  @@map("room_cleaning_types")
}

model RoomCleaningSopStep {
  id                        String    @id @default(uuid()) @db.Uuid
  /// Auto-generated S.No for display; renumbered by app on delete
  slid                      Int       @map("slid")
  cleaningTypeId            String    @map("cleaning_type_id") @db.Uuid
  stepNumber                Int       @map("step_number")
  /// Display string e.g. "00:05" — INTERVAL column handled by DB separately
  timeAllottedDisplay       String?   @map("time_allotted_display") @db.VarChar(10)
  /// TypeA=Dry, TypeB=Wet, TypeC=Sanitization
  cleaningMethod            String    @map("cleaning_method") @db.VarChar(10)
  /// Before | After | NA
  equipmentCleaningSequence String    @default("NA") @map("equipment_cleaning_sequence") @db.VarChar(10)
  procedureText             String    @map("procedure_text")
  chemicalUsed              String?   @map("chemical_used") @db.VarChar(200)
  /// pending | approved | rejected | archived
  status                    String    @default("approved") @map("status") @db.VarChar(20)
  authorizedBy              String?   @map("authorized_by") @db.Uuid
  authorizedAt              DateTime? @map("authorized_at") @db.Timestamptz(6)
  authorizationRemarks      String?   @map("authorization_remarks")
  createdBy                 String?   @map("created_by") @db.Uuid
  updatedBy                 String?   @map("updated_by") @db.Uuid
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  cleaningType     RoomCleaningType @relation(fields: [cleaningTypeId], references: [id], onDelete: Restrict)
  createdByUser    User?            @relation("RoomCleaningSopStepCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser    User?            @relation("RoomCleaningSopStepUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  authorizedByUser User?            @relation("RoomCleaningSopStepAuthorizedBy", fields: [authorizedBy], references: [id], onDelete: SetNull)

  @@unique([cleaningTypeId, stepNumber], name: "uq_step_per_type")
  @@index([cleaningTypeId, stepNumber])
  @@index([status])
  @@map("room_cleaning_sop_steps")
}

model RoomInspection1SopStep {
  id                   String    @id @default(uuid()) @db.Uuid
  /// Auto-generated S.No for display; renumbered by app on delete
  slid                 Int       @map("slid")
  cleaningTypeId       String    @map("cleaning_type_id") @db.Uuid
  stepNumber           Int       @map("step_number")
  procedureText        String    @map("procedure_text")
  /// pending | approved | rejected | archived
  status               String    @default("approved") @map("status") @db.VarChar(20)
  authorizedBy         String?   @map("authorized_by") @db.Uuid
  authorizedAt         DateTime? @map("authorized_at") @db.Timestamptz(6)
  authorizationRemarks String?   @map("authorization_remarks")
  createdBy            String?   @map("created_by") @db.Uuid
  updatedBy            String?   @map("updated_by") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  cleaningType  RoomCleaningType               @relation(fields: [cleaningTypeId], references: [id], onDelete: Restrict)
  createdByUser User?                          @relation("RoomInspection1SopStepCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser User?                          @relation("RoomInspection1SopStepUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  media         RoomInspection1SopStepMedia[]

  @@unique([cleaningTypeId, stepNumber], name: "uq_insp1_step_per_type")
  @@index([cleaningTypeId, stepNumber])
  @@index([status])
  @@map("room_inspection1_sop_steps")
}

model RoomInspection1SopStepMedia {
  id           String   @id @default(uuid()) @db.Uuid
  sopStepId    String   @map("sop_step_id") @db.Uuid
  displayOrder Int      @default(1) @map("display_order")
  fileUrl      String   @map("file_url") @db.VarChar(500)
  fileName     String?  @map("file_name") @db.VarChar(255)
  fileType     String?  @map("file_type") @db.VarChar(100)
  caption      String?  @map("caption")
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sopStep        RoomInspection1SopStep @relation(fields: [sopStepId], references: [id], onDelete: Cascade)
  uploadedByUser User?                  @relation("Insp1MediaUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([sopStepId, displayOrder])
  @@map("room_inspection1_sop_step_media")
}

// ── Inspection 2 ──────────────────────────────────────────────────────────────

model RoomInspection2SopStep {
  id                   String    @id @default(uuid()) @db.Uuid
  slid                 Int       @map("slid")
  cleaningTypeId       String    @map("cleaning_type_id") @db.Uuid
  stepNumber           Int       @map("step_number")
  procedureText        String    @map("procedure_text")
  status               String    @default("approved") @map("status") @db.VarChar(20)
  authorizedBy         String?   @map("authorized_by") @db.Uuid
  authorizedAt         DateTime? @map("authorized_at") @db.Timestamptz(6)
  authorizationRemarks String?   @map("authorization_remarks")
